<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATTERN" value=" %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n" />
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />

    <springProfile name="cluster">
        <appender name="Console"
                  class="ch.qos.logback.core.ConsoleAppender">
            <layout class="ch.qos.logback.classic.PatternLayout">
                <Pattern>
                    %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n
                </Pattern>
            </layout>
        </appender>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">

            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
            <!--current log file-->
            <file>gwas-submission-import-pipeline.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- rollover daily -->
                <fileNamePattern>gwas-submission-import-pipeline.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <!--determines when we rollover-->
                <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                    <maxFileSize>20MB</maxFileSize>
                </timeBasedFileNamingAndTriggeringPolicy>
                <maxHistory>100</maxHistory>
            </rollingPolicy>
        </appender>
        <root level="error">
            <appender-ref ref="FILE"/>
        </root>

        <logger name="uk.ac.ebi.spot.gwas" level="INFO" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>

    <springProfile name="sandbox">
        <appender name="Console"
                  class="ch.qos.logback.core.ConsoleAppender">
            <layout class="ch.qos.logback.classic.PatternLayout">
                <Pattern>
                    %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n
                </Pattern>
            </layout>
        </appender>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">

            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
            <!--current log file-->
            <file>gwas-submission-import-pipeline-sandbox.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- rollover daily -->
                <fileNamePattern>gwas-submission-import-pipeline-sandbox.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <!--determines when we rollover-->
                <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                    <maxFileSize>20MB</maxFileSize>
                </timeBasedFileNamingAndTriggeringPolicy>
                <maxHistory>100</maxHistory>
            </rollingPolicy>
        </appender>
        <root level="error">
            <appender-ref ref="FILE"/>
        </root>

        <logger name="uk.ac.ebi.spot.gwas" level="INFO" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>


    <springProfile name="local">
        <property name="LOG_PATH" value="logs" />
        <appender name="Console"
                  class="ch.qos.logback.core.ConsoleAppender">
            <layout class="ch.qos.logback.classic.PatternLayout">
                <Pattern>
                    %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n
                </Pattern>
            </layout>
        </appender>

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="error">
            <appender-ref ref="CONSOLE"/>

        </root>

        <logger name="uk.ac.ebi.spot.gwas" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

    </springProfile>
</configuration>
